<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/search"
    android:background="#F5F1E9"
    tools:context=".search">

    <LinearLayout
        android:id="@+id/search_panel"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <EditText
            android:id="@+id/search_input"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:background="@drawable/search_input_background"
            android:padding="16dp"
            android:hint="Buscar..."
            android:textColorHint="#757575" />

        <Button
            android:id="@+id/search_button"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginStart="12dp"
            android:elevation="3dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:backgroundTint="#4A7BA7"
            app:cornerRadius="18dp"
            app:icon="@drawable/rounded_forward_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="30dp" />

    </LinearLayout>
    <LinearLayout
        android:id="@+id/sOptions"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:layout_constraintTop_toBottomOf="@id/search_panel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#DCD3C2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/typeBtn"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:elevation="3dp"
            android:insetLeft="20dp"
            android:insetTop="7dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:backgroundTint="#4A7BA7"
            app:cornerRadius="18dp"
            app:icon="@drawable/rounded_keyboard_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="30dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/micbtn"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:elevation="3dp"
            android:insetLeft="0dp"
            android:insetTop="7dp"
            android:insetRight="20dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:backgroundTint="#4A7BA7"
            app:cornerRadius="18dp"
            app:icon="@drawable/rounded_mic_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="30dp" />
    </LinearLayout>

    <View
        android:id="@+id/search_border"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="#4A7BA7"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="@id/search_panel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/search_back"
        style="@style/Widget.MaterialComponents.Button.Icon"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        android:layout_marginBottom="10dp"
        android:layout_marginStart="10dp"
        app:backgroundTint="#4A7BA7"
        app:cornerRadius="50dp"
        app:icon="@drawable/rounded_arrow_back_ios_new_24"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/listen"
        style="@style/Widget.MaterialComponents.Button.Icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="50dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        app:backgroundTint="#4A7BA7"
        app:cornerRadius="50dp"
        app:icon="@drawable/rounded_circle_circle_24"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/search_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/sOptions"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/noInternet"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:alpha="0.5"
        android:scaleType="fitCenter"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/rounded_android_wifi_4_bar_alert_24"
        app:tint="#757575" />

    <TextView
        android:id="@+id/wrng1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/amaranth"
        android:text="Hubo un error"
        android:textColor="#757575"
        android:textSize="34sp"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/noInternet" />

</androidx.constraintlayout.widget.ConstraintLayout>